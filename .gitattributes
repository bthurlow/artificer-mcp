# Normalize line endings to LF for all text files, regardless of platform.
# Prevents CRLF from creeping in on Windows (which would fail Prettier's
# LF check in CI).
* text=auto eol=lf

# Explicit binary — Git won't try to normalize these
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.mp4 binary
*.mp3 binary
*.wav binary
*.pdf binary

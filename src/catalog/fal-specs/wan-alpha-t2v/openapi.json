{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/wan-alpha",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/wan-alpha queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/wan-alpha",
      "category": "text-to-video",
      "thumbnailUrl": "https://v3b.fal.media/files/b/lion/3oIcvX_9oIQh2cDai8geS_59a419be75fb46c5bd8094bb50e9cabf.jpg",
      "playgroundUrl": "https://fal.ai/models/fal-ai/wan-alpha",
      "documentationUrl": "https://fal.ai/models/fal-ai/wan-alpha/api"
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "WanAlphaInput": {
        "properties": {
          "sampler": {
            "enum": [
              "unipc",
              "dpm++",
              "euler"
            ],
            "description": "The sampler to use.",
            "default": "euler",
            "type": "string",
            "title": "Sampler"
          },
          "enable_safety_checker": {
            "description": "Whether to enable safety checker.",
            "default": true,
            "type": "boolean",
            "title": "Enable Safety Checker"
          },
          "num_inference_steps": {
            "minimum": 2,
            "maximum": 16,
            "description": "The number of inference steps to use.",
            "default": 8,
            "type": "integer",
            "title": "Number of Inference Steps"
          },
          "seed": {
            "description": "The seed for the random number generator.",
            "title": "Seed",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          },
          "mask_clamp_upper": {
            "minimum": 0,
            "maximum": 1,
            "description": "The upper bound of the mask clamping.",
            "default": 0.75,
            "type": "number",
            "title": "Mask Clamp Upper"
          },
          "binarize_mask": {
            "description": "Whether to binarize the mask.",
            "default": false,
            "type": "boolean",
            "title": "Binarize Mask"
          },
          "enable_prompt_expansion": {
            "description": "Whether to enable prompt expansion.",
            "default": false,
            "type": "boolean",
            "title": "Enable Prompt Expansion"
          },
          "shift": {
            "minimum": 1,
            "maximum": 15,
            "description": "The shift of the generated video.",
            "default": 10.5,
            "type": "number",
            "title": "Shift"
          },
          "video_quality": {
            "enum": [
              "low",
              "medium",
              "high",
              "maximum"
            ],
            "description": "The quality of the generated video.",
            "default": "high",
            "type": "string",
            "title": "Video Quality"
          },
          "mask_binarization_threshold": {
            "minimum": 0,
            "maximum": 1,
            "description": "The threshold for mask binarization. When binarize_mask is True, this threshold will be used to binarize the mask. This will also be used for transparency when the output type is `.webm`.",
            "default": 0.8,
            "type": "number",
            "title": "Mask Binarization Threshold"
          },
          "aspect_ratio": {
            "enum": [
              "16:9",
              "1:1",
              "9:16"
            ],
            "description": "The aspect ratio of the generated video.",
            "default": "16:9",
            "type": "string",
            "title": "Aspect Ratio"
          },
          "prompt": {
            "title": "Prompt",
            "description": "The prompt to guide the video generation.",
            "type": "string",
            "examples": [
              "Medium shot. A little girl holds a bubble wand and blows out colorful bubbles that float and pop in the air. The background of this video is transparent. Realistic style."
            ]
          },
          "mask_clamp_lower": {
            "minimum": 0,
            "maximum": 1,
            "description": "The lower bound of the mask clamping.",
            "default": 0.1,
            "type": "number",
            "title": "Mask Clamp Lower"
          },
          "sync_mode": {
            "description": "If `True`, the media will be returned as a data URI and the output data won't be available in the request history.",
            "default": false,
            "type": "boolean",
            "title": "Sync Mode"
          },
          "fps": {
            "minimum": 1,
            "maximum": 60,
            "description": "The frame rate of the generated video.",
            "default": 16,
            "type": "integer",
            "title": "FPS"
          },
          "resolution": {
            "enum": [
              "240p",
              "360p",
              "480p",
              "580p",
              "720p"
            ],
            "description": "The resolution of the generated video.",
            "default": "480p",
            "type": "string",
            "title": "Resolution"
          },
          "video_output_type": {
            "enum": [
              "X264 (.mp4)",
              "VP9 (.webm)",
              "PRORES4444 (.mov)",
              "GIF (.gif)"
            ],
            "description": "The output type of the generated video.",
            "default": "VP9 (.webm)",
            "type": "string",
            "title": "Video Output Type"
          },
          "num_frames": {
            "minimum": 17,
            "maximum": 121,
            "description": "The number of frames to generate.",
            "default": 81,
            "type": "integer",
            "title": "Number of Frames"
          },
          "video_write_mode": {
            "enum": [
              "fast",
              "balanced",
              "small"
            ],
            "description": "The write mode of the generated video.",
            "default": "balanced",
            "type": "string",
            "title": "Video Write Mode"
          }
        },
        "required": [
          "prompt"
        ],
        "x-fal-order-properties": [
          "prompt",
          "num_frames",
          "fps",
          "num_inference_steps",
          "seed",
          "sampler",
          "shift",
          "resolution",
          "aspect_ratio",
          "enable_prompt_expansion",
          "enable_safety_checker",
          "mask_clamp_lower",
          "mask_clamp_upper",
          "binarize_mask",
          "mask_binarization_threshold",
          "video_output_type",
          "video_quality",
          "video_write_mode",
          "sync_mode"
        ],
        "type": "object",
        "title": "WanAlphaRequest"
      },
      "WanAlphaOutput": {
        "properties": {
          "seed": {
            "title": "Seed",
            "description": "The seed used for generation.",
            "type": "integer",
            "examples": [
              424911732
            ]
          },
          "video": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/VideoFile"
              },
              {
                "type": "null"
              }
            ],
            "description": "The generated video file.",
            "examples": [
              {
                "url": "https://storage.googleapis.com/falserverless/example_outputs/wan-alpha-rgba-output.webm",
                "file_name": "wan-alpha-rgba-output.webm",
                "height": 720,
                "width": 1280,
                "content_type": "video/webm"
              }
            ]
          },
          "prompt": {
            "title": "Prompt",
            "description": "The prompt used for generation.",
            "type": "string",
            "examples": [
              "Medium shot. A little girl holds a bubble wand and blows out colorful bubbles that float and pop in the air. The background of this video is transparent. Realistic style."
            ]
          },
          "mask": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/VideoFile"
              },
              {
                "type": "null"
              }
            ],
            "description": "The generated mask file.",
            "examples": [
              {
                "height": 720,
                "duration": 5.0625,
                "fps": 16,
                "file_name": "wan-alpha-mask-output.webm",
                "url": "https://storage.googleapis.com/falserverless/example_outputs/wan-alpha-mask-output.webm",
                "width": 1280,
                "num_frames": 81,
                "content_type": "video/webm"
              }
            ]
          },
          "image": {
            "description": "The generated image file.",
            "anyOf": [
              {
                "$ref": "#/components/schemas/VideoFile"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "prompt",
          "seed"
        ],
        "x-fal-order-properties": [
          "prompt",
          "seed",
          "video",
          "image",
          "mask"
        ],
        "type": "object",
        "title": "WanAlphaResponse"
      },
      "VideoFile": {
        "properties": {
          "height": {
            "description": "The height of the video",
            "title": "Height",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          },
          "duration": {
            "description": "The duration of the video",
            "title": "Duration",
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "file_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "The size of the file in bytes.",
            "title": "File Size",
            "examples": [
              4404019
            ]
          },
          "url": {
            "description": "The URL where the file can be downloaded from.",
            "type": "string",
            "title": "Url"
          },
          "file_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "The name of the file. It will be auto-generated if not provided.",
            "title": "File Name",
            "examples": [
              "z9RV14K95DvU.png"
            ]
          },
          "fps": {
            "description": "The FPS of the video",
            "title": "Fps",
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "width": {
            "description": "The width of the video",
            "title": "Width",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          },
          "num_frames": {
            "description": "The number of frames in the video",
            "title": "Num Frames",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          },
          "content_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "The mime type of the file.",
            "title": "Content Type",
            "examples": [
              "image/png"
            ]
          }
        },
        "required": [
          "url"
        ],
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size",
          "width",
          "height",
          "fps",
          "duration",
          "num_frames"
        ],
        "type": "object",
        "title": "VideoFile"
      }
    }
  },
  "paths": {
    "/fal-ai/wan-alpha/requests/{request_id}/status": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          },
          {
            "name": "logs",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Whether to include logs (`1`) in the response or not (`0`)."
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueStatus"
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/wan-alpha/requests/{request_id}/cancel": {
      "put": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request was cancelled.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "Whether the request was cancelled successfully."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/wan-alpha": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WanAlphaInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The request status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueStatus"
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/wan-alpha/requests/{request_id}": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Result of the request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WanAlphaOutput"
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://queue.fal.run"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ]
}

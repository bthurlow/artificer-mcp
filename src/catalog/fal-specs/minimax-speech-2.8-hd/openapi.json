{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/minimax/speech-2.8-hd",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/minimax/speech-2.8-hd queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/minimax/speech-2.8-hd",
      "category": "text-to-speech",
      "thumbnailUrl": "https://v3b.fal.media/files/b/0a8d0e4a/5FhhsQ0BicVC_DZ_BDLGL_895a8e6af34848f8844c20244c3e4672.jpg",
      "playgroundUrl": "https://fal.ai/models/fal-ai/minimax/speech-2.8-hd",
      "documentationUrl": "https://fal.ai/models/fal-ai/minimax/speech-2.8-hd/api"
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "MinimaxSpeech28HdInput": {
        "x-fal-order-properties": [
          "prompt",
          "voice_setting",
          "audio_setting",
          "language_boost",
          "output_format",
          "pronunciation_dict",
          "normalization_setting",
          "voice_modify"
        ],
        "required": [
          "prompt"
        ],
        "title": "TextToSpeechHD28Request",
        "description": "Request model for Speech 2.8 HD - highest quality speech synthesis.",
        "type": "object",
        "properties": {
          "normalization_setting": {
            "description": "Loudness normalization settings for the audio",
            "$ref": "#/components/schemas/LoudnessNormalizationSetting"
          },
          "voice_setting": {
            "description": "Voice configuration settings",
            "$ref": "#/components/schemas/VoiceSetting",
            "default": {
              "english_normalization": false,
              "speed": 1,
              "vol": 1,
              "voice_id": "Wise_Woman",
              "pitch": 0
            }
          },
          "audio_setting": {
            "description": "Audio configuration settings",
            "$ref": "#/components/schemas/AudioSetting"
          },
          "language_boost": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "Chinese",
                  "Chinese,Yue",
                  "English",
                  "Arabic",
                  "Russian",
                  "Spanish",
                  "French",
                  "Portuguese",
                  "German",
                  "Turkish",
                  "Dutch",
                  "Ukrainian",
                  "Vietnamese",
                  "Indonesian",
                  "Japanese",
                  "Italian",
                  "Korean",
                  "Thai",
                  "Polish",
                  "Romanian",
                  "Greek",
                  "Czech",
                  "Finnish",
                  "Hindi",
                  "Bulgarian",
                  "Danish",
                  "Hebrew",
                  "Malay",
                  "Slovak",
                  "Swedish",
                  "Croatian",
                  "Hungarian",
                  "Norwegian",
                  "Slovenian",
                  "Catalan",
                  "Nynorsk",
                  "Afrikaans",
                  "auto"
                ]
              },
              {
                "type": "null"
              }
            ],
            "description": "Enhance recognition of specified languages and dialects",
            "title": "Language Boost"
          },
          "output_format": {
            "description": "Format of the output content (non-streaming only)",
            "title": "Output Format",
            "type": "string",
            "enum": [
              "url",
              "hex"
            ],
            "default": "hex"
          },
          "prompt": {
            "maxLength": 10000,
            "description": "Text to convert to speech. Use `<#x#>` for pauses (x = 0.01-99.99 seconds). Supports interjection tags: `(laughs)`, `(sighs)`, `(coughs)`, `(clears throat)`, `(gasps)`, `(sniffs)`, `(groans)`, `(yawns)`.",
            "title": "Prompt",
            "type": "string",
            "examples": [
              "Hello world! Welcome to MiniMax's new text to speech model <#0.1#> Speech 2.8 HD (laughs) now available on Fal!"
            ],
            "minLength": 1
          },
          "pronunciation_dict": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PronunciationDict"
              },
              {
                "type": "null"
              }
            ],
            "description": "Custom pronunciation dictionary for text replacement"
          },
          "voice_modify": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/VoiceModify"
              },
              {
                "type": "null"
              }
            ],
            "description": "Voice modification settings to adjust pitch, intensity, and timbre."
          }
        }
      },
      "MinimaxSpeech28HdOutput": {
        "x-fal-order-properties": [
          "audio",
          "duration_ms"
        ],
        "required": [
          "audio",
          "duration_ms"
        ],
        "title": "TextToSpeechHD28Output",
        "description": "Output model for Speech 2.8 HD.",
        "type": "object",
        "properties": {
          "duration_ms": {
            "description": "Duration of the audio in milliseconds",
            "title": "Duration Ms",
            "type": "integer"
          },
          "audio": {
            "description": "The generated audio file",
            "$ref": "#/components/schemas/File",
            "examples": [
              {
                "url": "https://v3b.fal.media/files/b/0a8d0bda/pF8woD8Iafl8vL6BMk4k4_speech.mp3"
              }
            ]
          }
        }
      },
      "LoudnessNormalizationSetting": {
        "x-fal-order-properties": [
          "enabled",
          "target_loudness",
          "target_range",
          "target_peak"
        ],
        "title": "LoudnessNormalizationSetting",
        "type": "object",
        "properties": {
          "target_loudness": {
            "maximum": -10,
            "minimum": -70,
            "description": "Target loudness in LUFS (default -18.0)",
            "title": "Target Loudness",
            "type": "number",
            "default": -18
          },
          "enabled": {
            "description": "Enable loudness normalization for the audio",
            "title": "Enabled",
            "type": "boolean",
            "default": true
          },
          "target_peak": {
            "maximum": 0,
            "minimum": -3,
            "description": "Target peak level in dBTP (default -0.5).",
            "title": "Target Peak",
            "type": "number",
            "default": -0.5
          },
          "target_range": {
            "maximum": 20,
            "minimum": 0,
            "description": "Target loudness range in LU (default 8.0)",
            "title": "Target Range",
            "type": "number",
            "default": 8
          }
        }
      },
      "VoiceSetting": {
        "x-fal-order-properties": [
          "voice_id",
          "speed",
          "vol",
          "pitch",
          "emotion",
          "english_normalization"
        ],
        "title": "VoiceSetting",
        "type": "object",
        "properties": {
          "english_normalization": {
            "description": "Enables English text normalization to improve number reading performance, with a slight increase in latency",
            "title": "English Normalization",
            "type": "boolean",
            "default": false
          },
          "emotion": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "happy",
                  "sad",
                  "angry",
                  "fearful",
                  "disgusted",
                  "surprised",
                  "neutral"
                ]
              },
              {
                "type": "null"
              }
            ],
            "description": "Emotion of the generated speech",
            "title": "Emotion"
          },
          "speed": {
            "maximum": 2,
            "minimum": 0.5,
            "description": "Speech speed (0.5-2.0)",
            "title": "Speed",
            "type": "number",
            "default": 1
          },
          "vol": {
            "maximum": 10,
            "minimum": 0.01,
            "description": "Volume (0-10)",
            "title": "Vol",
            "type": "number",
            "default": 1
          },
          "voice_id": {
            "default": "Wise_Woman",
            "description": "Predefined voice ID to use for synthesis",
            "title": "Voice Id",
            "type": "string",
            "examples": [
              "Wise_Woman",
              "Friendly_Person",
              "Inspirational_girl",
              "Deep_Voice_Man",
              "Calm_Woman",
              "Casual_Guy",
              "Lively_Girl",
              "Patient_Man",
              "Young_Knight",
              "Determined_Man",
              "Lovely_Girl",
              "Decent_Boy",
              "Imposing_Manner",
              "Elegant_Man",
              "Abbess",
              "Sweet_Girl_2",
              "Exuberant_Girl"
            ],
            "minLength": 1
          },
          "pitch": {
            "maximum": 12,
            "minimum": -12,
            "description": "Voice pitch (-12 to 12)",
            "title": "Pitch",
            "type": "integer",
            "default": 0
          }
        }
      },
      "AudioSetting": {
        "x-fal-order-properties": [
          "sample_rate",
          "bitrate",
          "format",
          "channel"
        ],
        "title": "AudioSetting",
        "type": "object",
        "properties": {
          "bitrate": {
            "description": "Bitrate of generated audio",
            "title": "Bitrate",
            "type": "integer",
            "enum": [
              32000,
              64000,
              128000,
              256000
            ],
            "default": 128000
          },
          "sample_rate": {
            "description": "Sample rate of generated audio",
            "title": "Sample Rate",
            "type": "integer",
            "enum": [
              8000,
              16000,
              22050,
              24000,
              32000,
              44100
            ],
            "default": 32000
          },
          "format": {
            "description": "Audio format",
            "title": "Format",
            "type": "string",
            "enum": [
              "mp3",
              "pcm",
              "flac"
            ],
            "default": "mp3"
          },
          "channel": {
            "description": "Number of audio channels (1=mono, 2=stereo)",
            "title": "Channel",
            "type": "integer",
            "enum": [
              1,
              2
            ],
            "default": 1
          }
        }
      },
      "PronunciationDict": {
        "x-fal-order-properties": [
          "tone_list"
        ],
        "title": "PronunciationDict",
        "type": "object",
        "properties": {
          "tone_list": {
            "description": "List of pronunciation replacements in format ['text/(pronunciation)', ...]. For Chinese, tones are 1-5. Example: ['燕少飞/(yan4)(shao3)(fei1)']",
            "title": "Tone List",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "VoiceModify": {
        "x-fal-order-properties": [
          "pitch",
          "intensity",
          "timbre"
        ],
        "description": "Voice modification settings for Speech 2.8 models.",
        "title": "VoiceModify",
        "type": "object",
        "properties": {
          "intensity": {
            "maximum": 100,
            "minimum": -100,
            "description": "Intensity/energy of the voice. Range: -100 to 100. Higher values create more energetic speech.",
            "title": "Intensity",
            "type": "integer",
            "default": 0
          },
          "pitch": {
            "maximum": 100,
            "minimum": -100,
            "description": "Pitch adjustment in semitones. Range: -100 to 100. Positive values raise pitch, negative values lower it.",
            "title": "Pitch",
            "type": "integer",
            "default": 0
          },
          "timbre": {
            "maximum": 100,
            "minimum": -100,
            "description": "Timbre adjustment. Range: -100 to 100. Affects the tonal quality of the voice.",
            "title": "Timbre",
            "type": "integer",
            "default": 0
          }
        }
      },
      "File": {
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size"
        ],
        "required": [
          "url"
        ],
        "title": "File",
        "type": "object",
        "properties": {
          "content_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "The mime type of the file.",
            "title": "Content Type",
            "examples": [
              "image/png"
            ]
          },
          "url": {
            "description": "The URL where the file can be downloaded from.",
            "title": "Url",
            "type": "string"
          },
          "file_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "The name of the file. It will be auto-generated if not provided.",
            "title": "File Name",
            "examples": [
              "z9RV14K95DvU.png"
            ]
          },
          "file_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "The size of the file in bytes.",
            "title": "File Size",
            "examples": [
              4404019
            ]
          }
        }
      }
    }
  },
  "paths": {
    "/fal-ai/minimax/speech-2.8-hd/requests/{request_id}/status": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          },
          {
            "name": "logs",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Whether to include logs (`1`) in the response or not (`0`)."
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueStatus"
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/minimax/speech-2.8-hd/requests/{request_id}/cancel": {
      "put": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request was cancelled.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "Whether the request was cancelled successfully."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/minimax/speech-2.8-hd": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MinimaxSpeech28HdInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The request status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueStatus"
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/minimax/speech-2.8-hd/requests/{request_id}": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Result of the request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MinimaxSpeech28HdOutput"
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://queue.fal.run"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ]
}

      "playgroundUrl": "https://fal.ai/models/fal-ai/ltx-2.3-22b/distilled/text-to-video",
      "documentationUrl": "https://fal.ai/models/fal-ai/ltx-2.3-22b/distilled/text-to-video/api"
    }
  },
  "components": {

        "properties": {
          "height": {
            "default": 512,
            "maximum": 14142,
            "type": "integer",
            "title": "Height",
            "description": "The height of the generated image.",
            "exclusiveMinimum": 0
          },
          "width": {
            "default": 512,
            "maximum": 14142,
            "type": "integer",
            "title": "Width",
            "description": "The width of the generated image.",
            "exclusiveMinimum": 0
          }
        }
      },
      "VideoFile": {
        "type": "object",
        "title": "VideoFile",
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size",
          "width",
          "height",
          "fps",
          "duration",
          "num_frames"
        ],
        "properties": {
          "file_size": {
            "description": "The size of the file in bytes.",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Size",
            "examples": [
              4404019
            ]
          },
          "duration": {
            "description": "The duration of the video",
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration"
          },
          "file_name": {
            "description": "The name of the file. It will be auto-generated if not provided.",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Name",
            "examples": [
              "z9RV14K95DvU.png"
            ]
          },
          "fps": {
            "description": "The FPS of the video",
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Fps"
          },
          "content_type": {
            "description": "The mime type of the file.",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content Type",
            "examples": [
              "image/png"
            ]
          },
          "height": {
            "description": "The height of the video",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Height"
          },
          "url": {
            "type": "string",
            "title": "Url",
            "description": "The URL where the file can be downloaded from."
          },
          "num_frames": {
            "description": "The number of frames in the video",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Num Frames"
          },
          "width": {
            "description": "The width of the video",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Width"
          }
        },
        "required": [

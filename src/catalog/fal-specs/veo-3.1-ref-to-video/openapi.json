  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "Veo31ReferenceToVideoInput": {
        "title": "Veo31ReferenceToVideoInput",
        "properties": {
          "resolution": {
            "enum": [
              "720p",
              "1080p",
              "4k"
            ],
            "description": "The resolution of the generated video.",
            "default": "720p",
            "title": "Resolution",
            "type": "string"
          },
          "safety_tolerance": {
            "enum": [
              "1",
              "2",
              "3",
              "4",
              "5",
              "6"
            ],
            "description": "The safety tolerance level for content moderation. 1 is the most strict (blocks most content), 6 is the least strict.",
            "default": "4",
            "title": "Safety Tolerance",
            "type": "string"
          },
          "generate_audio": {
            "description": "Whether to generate audio for the video.",
            "default": true,
            "title": "Generate Audio",
            "type": "boolean"
          },
          "auto_fix": {
            "description": "Whether to automatically attempt to fix prompts that fail content policy or other validation checks by rewriting them.",
            "default": false,
            "title": "Auto Fix",
            "type": "boolean"
          },
          "prompt": {
            "description": "The text prompt describing the video you want to generate",
            "examples": [
              "A chimpanzee wearing overalls frolics in the grassy field, gently playing with the butterflies. In the background, a circus tent and carousel beckon."
            ],
            "maxLength": 20000,
            "title": "Prompt",
            "type": "string"
          },
          "aspect_ratio": {
            "enum": [
              "16:9",
              "9:16"
            ],
            "description": "The aspect ratio of the generated video.",
            "default": "16:9",
            "title": "Aspect Ratio",
            "type": "string"
          },
          "image_urls": {
            "description": "URLs of the reference images to use for consistent subject appearance",
            "items": {
              "type": "string"
            },
            "examples": [
              [
                "https://storage.googleapis.com/falserverless/example_inputs/veo31-r2v-input-1.png",
                "https://storage.googleapis.com/falserverless/example_inputs/veo31-r2v-input-2.png",
                "https://storage.googleapis.com/falserverless/example_inputs/veo31-r2v-input-3.png"
              ]
            ],
            "title": "Image Urls",
            "type": "array"
          },
          "duration": {
            "description": "The duration of the generated video.",
            "type": "string",
            "default": "8s",
            "title": "Duration",
            "const": "8s"
          }
        },
        "type": "object",
        "required": [
          "prompt",
          "image_urls"
        ],
        "x-fal-order-properties": [
          "prompt",
          "aspect_ratio",
          "duration",
          "resolution",
          "generate_audio",
          "auto_fix",
          "safety_tolerance",
          "image_urls"
        ]
      },
      "Veo31ReferenceToVideoOutput": {
        "title": "Veo31ReferenceToVideoOutput",
        "properties": {
          "video": {
            "description": "The generated video.",
            "examples": [
              {
                "url": "https://storage.googleapis.com/falserverless/example_outputs/veo31-r2v-output.mp4"
              }
            ],
            "$ref": "#/components/schemas/File"
          }
        },
        "type": "object",
        "required": [
          "video"
        ],
        "x-fal-order-properties": [
          "video"
        ]
      },
      "File": {
        "title": "File",
        "properties": {
          "content_type": {
            "description": "The mime type of the file.",
            "examples": [
              "image/png"
            ],
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content Type"
          },
          "file_name": {
            "description": "The name of the file. It will be auto-generated if not provided.",
            "examples": [
              "z9RV14K95DvU.png"
            ],
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Name"
          },
          "url": {
            "description": "The URL where the file can be downloaded from.",
            "title": "Url",
            "type": "string"
          },
          "file_size": {
            "description": "The size of the file in bytes.",
            "examples": [
              4404019
            ],
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Size"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size"
        ]
      }
    }
  },

{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/veo3.1/reference-to-video",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/veo3.1/reference-to-video queue.",
    "x-fal-metadata": {

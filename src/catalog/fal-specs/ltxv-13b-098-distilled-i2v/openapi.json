              }
            ]
          },
          "prompt": {
            "title": "Prompt",
            "description": "The prompt used for generation.",
            "type": "string",
            "examples": [
              "The astronaut gets up and walks away"
            ]
          },
          "seed": {
            "title": "Seed",
            "description": "The seed used for generation.",
            "type": "integer"
          }
        },

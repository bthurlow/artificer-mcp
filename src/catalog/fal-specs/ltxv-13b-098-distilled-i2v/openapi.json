              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "examples": [
              4404019
            ]
          },
          "file_name": {
            "title": "File Name",
            "description": "The name of the file. It will be auto-generated if not provided.",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "examples": [
              "z9RV14K95DvU.png"
            ]
          },
          "url": {
            "title": "Url",
            "description": "The URL where the file can be downloaded from.",
            "type": "string"
          }
        },
        "title": "File",
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size"
        ],
        "required": [

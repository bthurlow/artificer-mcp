  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "Sora2TextToVideoInput": {
        "properties": {
          "character_ids": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "maxItems": 2,
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "description": "Up to two character IDs (from create-character) to use in the video. Refer to characters by name in the prompt. When set, only the OpenAI provider is used.",
            "title": "Character IDs"
          },
          "detect_and_block_ip": {
            "description": "If enabled, the prompt (and image for image-to-video) will be checked for known intellectual property references and the request will be blocked if any are detected.",
            "title": "Detect And Block Ip",
            "default": false,
            "type": "boolean"
          },
          "model": {
            "default": "sora-2",
            "description": "The model to use for the generation. When the default model is selected, the latest snapshot of the model will be used - otherwise, select a specific snapshot of the model.",
            "title": "Model",
            "enum": [
              "sora-2",
              "sora-2-2025-12-08",
              "sora-2-2025-10-06"
            ],
            "type": "string"
          },
          "delete_video": {
            "description": "Whether to delete the video after generation for privacy reasons. If True, the video cannot be used for remixing and will be permanently deleted.",
            "title": "Delete Video",
            "default": true,
            "type": "boolean"
          },
          "resolution": {
            "const": "720p",
            "description": "The resolution of the generated video",
            "title": "Resolution",
            "default": "720p",
            "type": "string"
          },
          "duration": {
            "default": 4,
            "description": "Duration of the generated video in seconds",
            "title": "Duration",
            "enum": [
              4,
              8,
              12,
              16,
              20
            ],
            "type": "integer"
          },
          "aspect_ratio": {
            "default": "16:9",
            "description": "The aspect ratio of the generated video",
            "title": "Aspect Ratio",
            "enum": [
              "9:16",
              "16:9"
            ],
            "type": "string"
          },
          "prompt": {
            "description": "The text prompt describing the video you want to generate",
            "minLength": 1,
            "title": "Prompt",
            "examples": [
              "A dramatic Hollywood breakup scene at dusk on a quiet suburban street. A man and a woman in their 30s face each other, speaking softly but emotionally, lips syncing to breakup dialogue. Cinematic lighting, warm sunset tones, shallow depth of field, gentle breeze moving autumn leaves, realistic natural sound, no background music"
            ],
            "maxLength": 5000,
            "type": "string"
          }
        },
        "title": "TextToVideoInput",
        "required": [
          "prompt"
        ],
        "x-fal-order-properties": [
          "prompt",
          "resolution",
          "aspect_ratio",
          "duration",
          "delete_video",
          "model",
          "detect_and_block_ip",
          "character_ids"
        ],
        "type": "object"
      },
      "Sora2TextToVideoOutput": {
        "properties": {
          "spritesheet": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ImageFile"
              },
              {
                "type": "null"
              }
            ],
            "description": "Spritesheet image for the video"
          },
          "video_id": {
            "description": "The ID of the generated video",
            "title": "Video ID",
            "examples": [
              "video_123"
            ],
            "type": "string"
          },
          "video": {
            "description": "The generated video",
            "examples": [
              {
                "content_type": "video/mp4",
                "url": "https://storage.googleapis.com/falserverless/example_outputs/sora_t2v_output.mp4"
              }
            ],
            "$ref": "#/components/schemas/VideoFile"
          },
          "thumbnail": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ImageFile"
              },
              {
                "type": "null"
              }
            ],
            "description": "Thumbnail image for the video"
          }
        },
        "title": "TextToVideoOutput",
        "required": [
          "video",
          "video_id"
        ],
        "x-fal-order-properties": [
          "video",
          "video_id",
          "thumbnail",
          "spritesheet"
        ],
        "type": "object"
      },
      "ImageFile": {
        "properties": {
          "width": {
            "anyOf": [
              {
                "type": "integer"
              },

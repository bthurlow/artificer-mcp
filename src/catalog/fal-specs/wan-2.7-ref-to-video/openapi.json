      "playgroundUrl": "https://fal.ai/models/fal-ai/wan/v2.7/reference-to-video",
      "documentationUrl": "https://fal.ai/models/fal-ai/wan/v2.7/reference-to-video/api"
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "WanV27ReferenceToVideoInput": {
        "title": "Wan27ReferenceToVideoInput",
        "type": "object",
        "required": [
          "prompt"
        ],
        "x-fal-order-properties": [
          "prompt",
          "reference_image_urls",
          "reference_video_urls",
          "negative_prompt",
          "aspect_ratio",
          "resolution",
          "duration",
          "multi_shots",
          "seed",
          "enable_safety_checker"
        ],
        "properties": {
          "multi_shots": {
            "title": "Multi Shots",
            "type": "boolean",
            "default": false,
            "description": "When true, enables intelligent multi-shot segmentation. When false (default), generates a single continuous shot."
          },
          "reference_video_urls": {
            "title": "Reference Video Urls",
            "anyOf": [
              {
                "items": {
                  "limit_description": "Max file size: 100.0MB, Max duration: 30s, Timeout: 30.0s",
                  "_fal_ui_field": "video",
                  "ui": {
                    "field": "video"
                  },
                  "x-fal": {
                    "timeout": 30,
                    "max_file_size": 104857600,
                    "max_duration": 30
                  },
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "description": "Reference video URLs for character/object appearance and motion. Pass multiple videos for multi-subject generation. Max 100 MB each."
          },
          "negative_prompt": {
            "title": "Negative Prompt",
            "examples": [
              "low resolution, errors, worst quality, low quality"
            ],
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Content to avoid in the video. Max 500 characters."
          },
          "seed": {
            "title": "Seed",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "Random seed for reproducibility (0-2147483647)."
          },
          "enable_safety_checker": {
            "title": "Enable Safety Checker",
            "type": "boolean",
            "default": true,
            "description": "Enable content moderation for input and output."
          },
          "aspect_ratio": {
            "title": "Aspect Ratio",
            "enum": [
              "16:9",
              "9:16",
              "1:1",
              "4:3",
              "3:4"
            ],
            "type": "string",
            "default": "16:9",
            "description": "Aspect ratio of the generated video."
          },
          "prompt": {
            "title": "Prompt",
            "examples": [
              "A person walking through a beautiful garden, cinematic style."
            ],
            "minLength": 1,
            "type": "string",
            "description": "Text prompt describing the desired video. Max 5000 characters."
          },
          "reference_image_urls": {
            "title": "Reference Image Urls",
            "anyOf": [
              {
                "items": {
                  "_fal_ui_field": "image",
                  "ui": {
                    "field": "image"
                  },
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "description": "Reference image URLs for character/object appearance. Pass multiple images for multi-subject generation. Max 20 MB each."
          },
          "resolution": {
            "title": "Resolution",
            "enum": [
              "720p",
              "1080p"
            ],
            "type": "string",
            "default": "1080p",
            "description": "Output video resolution tier."
          },
          "duration": {
            "title": "Duration",
            "enum": [
              2,
              3,
              4,
              5,
              6,
              7,
              8,
              9,
              10
            ],
            "type": "integer",
            "examples": [
              5,
              10
            ],
            "default": 5,
            "description": "Output video duration in seconds (2-10)."
          }
        },
        "description": "Input for Wan 2.7 reference-to-video generation.\n\nSupports single or multi-character video generation from reference images\nand/or videos. Also supports multi-shot narration."
      },
      "WanV27ReferenceToVideoOutput": {
        "title": "Wan27ReferenceToVideoOutput",
        "type": "object",
        "required": [
          "video",
          "seed"
        ],
        "x-fal-order-properties": [
          "video",
          "seed",
          "actual_prompt"
        ],
        "properties": {
          "video": {
            "description": "The generated video file.",
            "$ref": "#/components/schemas/VideoFile"
          },
          "seed": {
            "title": "Seed",
            "type": "integer",
            "description": "The seed used for generation."
          },
          "actual_prompt": {
            "title": "Actual Prompt",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "The actual prompt used if prompt rewriting was enabled."
          }
        },
        "description": "Output for Wan 2.7 reference-to-video generation."
      },
      "VideoFile": {
        "properties": {
          "fps": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "The FPS of the video",
            "title": "Fps"
          },
          "height": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "The height of the video",
            "title": "Height"
          },
          "content_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "examples": [
              "image/png"
            ],
            "description": "The mime type of the file.",
            "title": "Content Type"
          },
          "duration": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "The duration of the video",
            "title": "Duration"
          },
          "file_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "examples": [
              4404019
            ],
            "description": "The size of the file in bytes.",
            "title": "File Size"
          },
          "width": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "The width of the video",
            "title": "Width"
          },
          "num_frames": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "The number of frames in the video",
            "title": "Num Frames"
          },
          "url": {
            "description": "The URL where the file can be downloaded from.",
            "type": "string",
            "title": "Url"
          },
          "file_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "examples": [
              "z9RV14K95DvU.png"
            ],
            "description": "The name of the file. It will be auto-generated if not provided.",
            "title": "File Name"
          }
        },
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size",
          "width",
          "height",
          "fps",
          "duration",
          "num_frames"
        ],
        "required": [
          "url"
        ],
        "type": "object",
        "title": "VideoFile"
      }
    }

        "required": [
          "video",
          "seed"
        ],
        "x-fal-order-properties": [
          "video",
          "seed",
          "actual_prompt"
        ],
        "description": "Output for Wan 2.7 text-to-video generation.",
        "type": "object",
        "title": "Wan27TextToVideoOutput",
        "properties": {
          "video": {
            "description": "The generated video file.",
            "$ref": "#/components/schemas/VideoFile"
          },
          "actual_prompt": {
            "description": "The actual prompt used if prompt rewriting was enabled.",

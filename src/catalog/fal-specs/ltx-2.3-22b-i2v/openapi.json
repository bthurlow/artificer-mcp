{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/ltx-2.3-22b/image-to-video",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/ltx-2.3-22b/image-to-video queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/ltx-2.3-22b/image-to-video",
      "category": "image-to-video",
      "thumbnailUrl": "https://v3b.fal.media/files/b/0a9289c9/kEEMVVpXrSdQAUe8zVqbg__tmp_b046-liqu-phoenix.jpg",
      "playgroundUrl": "https://fal.ai/models/fal-ai/ltx-2.3-22b/image-to-video",
      "documentationUrl": "https://fal.ai/models/fal-ai/ltx-2.3-22b/image-to-video/api"
